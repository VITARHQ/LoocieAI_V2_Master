ENV=dev
ENGINE_NAME=LoocieCoreAI Core Engine
ENGINE_VERSION=3.0.0

# REQUIRED for secured endpoints:
LOOCIE_INTERNAL_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Optional build/test unlock gate:
LOOCIE_TEXT_UNLOCK=CHANGE_ME_UNLOCK

MODEL_PROVIDER=ollama
MODEL_ENDPOINT=http://127.0.0.1:11434
MODEL_NAME=phi3:mini

CONNECT_TIMEOUT_SECONDS=2
READ_TIMEOUT_SECONDS=15
MEMORY_MAX_MESSAGES=12
WARMUP_ON_START=true
